# Copy to .env — defaults match docker-compose.yml

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Catalog service
CATALOG_PORT=3001
MONGO_URL=mongodb://localhost:27017/catalog

# Enrollment service
ENROLLMENT_PORT=3002
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=learnflow
POSTGRES_PASSWORD=learnflow
POSTGRES_DB=enrollment

# Notification service
NOTIFICATION_PORT=3003
